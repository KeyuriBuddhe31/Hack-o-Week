    <title>Shadows of the Savanna | Cheetah Gallery</title>
    <style>
        /* Modern & Minimalist Setup */
        * { box-sizing: border-box; }
        body { 
            font-family: 'Playfair Display', serif, 'Times New Roman'; 
            background-color: #0a0a0a; 
            color: #d4d4d4; 
            margin: 0; 
            padding: 0; 
            line-height: 1.6;
        }

        /* Header Section */
        header {
            text-align: center;
            padding: 80px 20px;
            background: linear-gradient(to bottom, #1a1a1a, #0a0a0a);
        }
        h1 { 
            font-size: 3rem; 
            margin: 0; 
            color: #fff; 
            letter-spacing: 6px; 
            text-transform: uppercase;
            font-weight: 300;
        }
        .subtitle { 
            font-style: italic; 
            color: #bfa15a; /* Gold/Savanna tone */
            letter-spacing: 2px;
            margin-top: 10px;
            display: block;
        }

        /* 1. The Grid (3x3 on Desktop) */
        .gallery {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            max-width: 1300px;
            margin: 0 auto 100px auto;
            padding: 0 20px;
        }

        .gallery a {
            overflow: hidden;
            border: 1px solid #222;
            display: block;
            background: #000;
        }

        .gallery a img {
            width: 100%;
            height: 400px;
            object-fit: cover;
            display: block;
            transition: transform 0.8s cubic-bezier(0.2, 1, 0.3, 1), opacity 0.5s;
            opacity: 0.8;
        }

        /* Hover Effect for a professional feel */
        .gallery a:hover img { 
            transform: scale(1.1); 
            opacity: 1;
        }

        /* 2. The Full-Screen Lightbox */
        .lightbox {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            background: rgba(0, 0, 0, 0.98);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            visibility: hidden;
            transition: all 0.4s ease;
            z-index: 9999;
        }

        /* 3. Show Lightbox on Click */
        .lightbox:target {
            opacity: 1;
            visibility: visible;
        }

        .lightbox img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        /* 4. Close Button */
        .close {
            position: absolute;
            top: 30px;
            right: 40px;
            font-size: 60px;
            color: #fff;
            text-decoration: none;
            font-weight: 100;
            transition: color 0.3s;
        }
        .close:hover { color: #bfa15a; }

        footer {
            text-align: center;
            padding: 40px;
            font-size: 0.8rem;
            color: #444;
            border-top: 1px solid #1a1a1a;
        }
    </style>
</head>
